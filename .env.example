# Server Configuration
NODE_ENV=development
PORT=3000
HOST=localhost

# Database Configuration (Supabase PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/database
DATABASE_POOL_MIN=10
DATABASE_POOL_MAX=50

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# AWS S3 Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
S3_BUCKET_NAME=course-platform-assets
S3_BUCKET_REGION=us-east-1
S3_ENABLE_TRANSFER_ACCELERATION=true

# AWS SQS Configuration (for video transcoding)
SQS_TRANSCODING_QUEUE_URL_HIGH=https://sqs.us-east-1.amazonaws.com/account/transcoding-high
SQS_TRANSCODING_QUEUE_URL_NORMAL=https://sqs.us-east-1.amazonaws.com/account/transcoding-normal
SQS_TRANSCODING_QUEUE_URL_LOW=https://sqs.us-east-1.amazonaws.com/account/transcoding-low
SQS_DEAD_LETTER_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/account/transcoding-dlq

# Supabase Auth Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_min_32_chars
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# OpenAI Configuration
OPENAI_API_KEY=sk-your_openai_api_key
OPENAI_MODEL=gpt-4
OPENAI_MAX_TOKENS=2000

# CORS Configuration
CORS_ORIGIN=http://localhost:5173
CORS_CREDENTIALS=true

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Video Upload Configuration
UPLOAD_CHUNK_SIZE_MB=100
UPLOAD_MAX_FILE_SIZE_GB=50
UPLOAD_SESSION_EXPIRY_DAYS=7
UPLOAD_MAX_CONCURRENT_PER_INSTRUCTOR=5
UPLOAD_DAILY_QUOTA_GB_STANDARD=500
UPLOAD_DAILY_QUOTA_GB_PREMIUM=2000
UPLOAD_TOKEN_BUCKET_REFILL_GB_PER_HOUR=10
UPLOAD_SYSTEM_CAPACITY_THRESHOLD=0.8

# Monitoring & Metrics
PROMETHEUS_METRICS_ENABLED=true
METRICS_PORT=9090
ALERT_SUCCESS_RATE_THRESHOLD=0.95
ALERT_UPLOAD_TIME_MULTIPLIER=2
ALERT_STORAGE_CAPACITY_THRESHOLD=0.7
ALERT_MONTHLY_COST_BUDGET_USD=10000

# Logging
LOG_LEVEL=info

# Email Configuration (Optional - for Resend)
RESEND_API_KEY=re_your_resend_api_key
FROM_EMAIL=noreply@courseplatform.com

# Frontend URL
FRONTEND_URL=http://localhost:5173

# CDN Configuration (Optional)
CDN_URL=https://cdn.courseplatform.com
